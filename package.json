{
  "name": "@2bbb/bbb-dmx-utils",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "bbb-dmx-convert": "dist/index.js",
    "bbb-dmx-lint": "dist/lint.js",
    "bbb-dmx-fixture-editor": "dist/web.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "convert": "npm run build --silent && node dist/index.js",
    "lint": "npm run build --silent && node dist/lint.js",
    "fixture-editor": "npm run build --silent && node dist/web.js",
    "smoke": "npm run build && node dist/index.js --help && node test/smoke.mjs && node test/web-smoke.mjs",
    "web": "node dist/web.js",
    "web:smoke": "npm run build && node test/web-smoke.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.8.0",
    "jszip": "^3.10.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "description": "Node.js utilities for bbb.dmx fixture conversion, JSON linting, and local fixture editing."
}
